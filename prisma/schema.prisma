generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  image       String
  url         String?
  createdAt   DateTime @default(now())
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logo      String
  createdAt DateTime @default(now())
}
